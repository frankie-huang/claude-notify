{
  "msg_type": "interactive",
  "card": {
    "schema": "2.0",
    "config": {
      "update_multi": true,
      "style": {
        "text_size": {
          "normal_v2": {
            "default": "normal",
            "pc": "normal",
            "mobile": "heading"
          }
        }
      }
    },
    "header": {
      "template": "blue",
      "title": {
        "tag": "lark_md",
        "content": "{{at_user}}🔵 用户提问 · AskUserQuestion"
      },
      "padding": "12px 8px 12px 8px"
    },
    "body": {
      "direction": "vertical",
      "elements": [
        {
          "tag": "column_set",
          "columns": [
            {
              "tag": "column",
              "width": "weighted",
              "elements": [
                {
                  "tag": "markdown",
                  "content": "**项目：**\n{{project_name}}",
                  "text_align": "left",
                  "text_size": "normal_v2"
                }
              ],
              "vertical_align": "top",
              "weight": 1
            },
            {
              "tag": "column",
              "width": "weighted",
              "elements": [
                {
                  "tag": "markdown",
                  "content": "**会话：**\n`{{session_id}}`",
                  "text_align": "left",
                  "text_size": "normal_v2"
                }
              ],
              "vertical_align": "top",
              "weight": 1
            },
            {
              "tag": "column",
              "width": "weighted",
              "elements": [
                {
                  "tag": "markdown",
                  "content": "**时间：**\n{{timestamp}}",
                  "text_align": "left",
                  "text_size": "normal_v2"
                }
              ],
              "vertical_align": "top",
              "weight": 1
            }
          ]
        },
        {
          "tag": "hr",
          "margin": "0px 0px 0px 0px"
        },
        {
          "tag": "form",
          "name": "ask_question_form",
          "elements": [
            {{ask_question_form_elements}},
            {
              "tag": "column_set",
              "flex_mode": "stretch",
              "horizontal_spacing": "10px",
              "horizontal_align": "left",
              "margin": "12px 0px 0px 0px",
              "columns": [
                {
                  "tag": "column",
                  "width": "auto",
                  "elements": [
                    {
                      "tag": "button",
                      "name": "submit_answer",
                      "text": {
                        "tag": "plain_text",
                        "content": "提交回答"
                      },
                      "type": "primary_filled",
                      "size": "medium",
                      "width": "fill",
                      "form_action_type": "submit",
                      "behaviors": [
                        {
                          "type": "callback",
                          "value": {
                            "action": "answer",
                            "request_id": "{{request_id}}",
                            "owner_id": "{{owner_id}}"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "tag": "column",
                  "width": "auto",
                  "elements": [
                    {
                      "tag": "button",
                      "name": "deny_answer",
                      "text": {
                        "tag": "plain_text",
                        "content": "拒绝回答"
                      },
                      "type": "danger",
                      "size": "medium",
                      "width": "fill",
                      "form_action_type": "submit",
                      "behaviors": [
                        {
                          "type": "callback",
                          "value": {
                            "action": "deny",
                            "request_id": "{{request_id}}",
                            "owner_id": "{{owner_id}}"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "tag": "column",
                  "width": "auto",
                  "elements": [
                    {
                      "tag": "button",
                      "name": "interrupt_answer",
                      "text": {
                        "tag": "plain_text",
                        "content": "拒绝并中断"
                      },
                      "type": "danger_filled",
                      "size": "medium",
                      "width": "fill",
                      "form_action_type": "submit",
                      "behaviors": [
                        {
                          "type": "callback",
                          "value": {
                            "action": "interrupt",
                            "request_id": "{{request_id}}",
                            "owner_id": "{{owner_id}}"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "text": {
            "tag": "plain_text",
            "content": "允许只回答部分问题，未回答的将留空。提交后不可重新修改，请确认后再提交。",
            "text_size": "notation",
            "text_align": "left",
            "text_color": "grey"
          }
        },
        {
          "tag": "hr",
          "margin": "0px 0px 0px 0px"
        },
        {
          "tag": "div",
          "text": {
            "tag": "lark_md",
            "content": "恢复会话：`claude --resume {{resume_session_id}}`",
            "text_size": "notation",
            "text_align": "left",
            "text_color": "grey"
          }
        }
      ]
    }
  }
}
